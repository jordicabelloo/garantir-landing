# PostgreSQL connection string (Neon, Railway, local, etc.)
DATABASE_URL=postgresql://user:password@host:5432/garantir_landing

# Email notifications (Resend - https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
NOTIFICATION_EMAIL=you@yourdomain.com

# Admin dashboard protection
ADMIN_SECRET=change-this-to-a-strong-secret

# App URL (used for CORS and email links)
NEXT_PUBLIC_APP_URL=https://garantir.io
